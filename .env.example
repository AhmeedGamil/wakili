# Copy this file to ".env" and edit as needed. Every value is optional — sensible
# defaults apply when a key is absent. Real shell environment variables override
# anything set here.

# Port the gateway listens on (default 8730).
# PORT=8730

# Shared access token that gates the gateway once it's reachable beyond the LAN.
# Leave unset to auto-generate and persist one to data/token.txt (stable across
# restarts). Set it explicitly only if you want a fixed, known token.
# REMOTE_AGENT_TOKEN=

# Which editor's Claude Code resume list your phone chats appear in. Known values:
# claude-vscode (default), cli, sdk-cli.
# REMOTE_AGENT_CLAUDE_ENTRYPOINT=claude-vscode

# Port the Cloudflare bridge listens on when you use `npm run cloudflare`
# (default 8731). Rarely needs changing.
# CF_BRIDGE_PORT=8731

# Keep the machine awake while the gateway runs so remote turns aren't suspended
# by idle sleep (the screen can still lock). On by default; set to 0 to opt out.
# You can also toggle it live from the app.
# REMOTE_AGENT_KEEP_AWAKE=1
