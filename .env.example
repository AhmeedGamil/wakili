# Copy this file to ".env" and edit as needed. Every value is optional — sensible
# defaults apply when a key is absent. Real shell environment variables override
# anything set here.
#
# Where to put it: next to server.mjs (a cloned repo), or in the runtime store at
# ~/.wakili/.env — the home-store location is recommended for `npm install -g`
# setups, since it survives package updates. Both are read; the repo file wins.

# Port the gateway listens on (default 8730).
# PORT=8730

# Shared access token that gates the gateway once it's reachable beyond the LAN.
# Leave unset to auto-generate and persist one to ~/.wakili/token.txt (stable
# across restarts). Set it explicitly only if you want a fixed, known token.
# WAKILI_TOKEN=

# Which editor's Claude Code resume list your phone chats appear in. Known values:
# claude-vscode (default), cli, sdk-cli.
# WAKILI_CLAUDE_ENTRYPOINT=claude-vscode

# Port the Cloudflare bridge listens on when you use `npm run cloudflare`
# (default 8731). Rarely needs changing.
# CF_BRIDGE_PORT=8731

# Keep the machine awake while the gateway runs so remote turns aren't suspended
# by idle sleep (the screen can still lock). On by default; set to 0 to opt out.
# You can also toggle it live from the app.
# WAKILI_KEEP_AWAKE=1

# Route outbound traffic — including every claude/codex process the gateway
# spawns — through an HTTP proxy. For networks where api.anthropic.com or
# api.openai.com are blocked. Format: http://user:pass@host:port (credentials
# optional). localhost/127.0.0.1 are excluded automatically, so the gateway's
# internal callbacks always stay direct.
# HTTPS_PROXY=http://user:pass@proxy.example.com:8888
# HTTP_PROXY=http://user:pass@proxy.example.com:8888

# Extra hosts that should bypass the proxy (comma-separated). Merged with the
# automatic localhost entries — you never need to list those.
# NO_PROXY=
